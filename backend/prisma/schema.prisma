generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER
  DISTRIBUTOR
  RETAILER
}

enum RequestStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  role             Role     @default(RETAILER)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile          Profile?
  wallet           Wallet?

  // Hierarchy bindings
  children         User[]   @relation("UserHierarchy")
  parent           User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  parentId         String?

  services         ServiceRequest[]
  transactionsSent WalletTransaction[] @relation("Sender")
  transactionsRecv WalletTransaction[] @relation("Receiver")
  
  overridesSet     UserCommissionSetup[] @relation("SetBy")
  overridesRecv    UserCommissionSetup[] @relation("Target")
}

model Profile {
  id               String   @id @default(uuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String   @unique
  ownerName        String
  shopName         String
  mobileNumber     String   @unique
  fullAddress      String
  state            String
  pinCode          String
  aadhaarNumber    String?
  aadhaarFrontPath String?
  aadhaarBackPath  String?
  panCardPath      String?
}

model Wallet {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  balance   Decimal  @default(0.00) @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id               String   @id @default(uuid())
  amount           Decimal  @db.Decimal(15, 2)
  type             String   // CREDIT, DEBIT
  description      String?
  status           RequestStatus @default(SUCCESS)
  
  sender           User?    @relation("Sender", fields: [senderId], references: [id])
  senderId         String?
  senderBalAfter   Decimal? @db.Decimal(15, 2)
  
  receiver         User     @relation("Receiver", fields: [receiverId], references: [id])
  receiverId       String
  receiverBalAfter Decimal  @db.Decimal(15, 2)

  createdAt        DateTime @default(now())
}

model CommissionSlab {
  id              String   @id @default(uuid())
  serviceType     String   // PAYOUT, ADD_FUND, TRANSACTION
  applyOnRole     Role
  commissionType  String   // FLAT, PERCENTAGE
  commissionValue Decimal  @default(0.00) @db.Decimal(15, 2)
  minAmount       Decimal? @db.Decimal(15, 2)
  maxAmount       Decimal? @db.Decimal(15, 2)
  isActive        Boolean  @default(true)
}

model UserCommissionSetup {
  id              String   @id @default(uuid())
  setBy           User     @relation("SetBy", fields: [setById], references: [id])
  setById         String
  targetUser      User     @relation("Target", fields: [targetUserId], references: [id])
  targetUserId    String
  serviceType     String
  commissionType  String   // FLAT, PERCENTAGE
  commissionValue Decimal  @default(0.00) @db.Decimal(15, 2)
  minAmount       Decimal? @db.Decimal(15, 2)
  maxAmount       Decimal? @db.Decimal(15, 2)
  isActive        Boolean  @default(true)

  @@unique([setById, targetUserId, serviceType])
}

model ServiceRequest {
  id               String   @id @default(uuid())
  user             User     @relation(fields: [userId], references: [id])
  userId           String
  serviceType      String   // BANK_VERIFICATION, FUND_REQUEST, PAYOUT
  amount           Decimal? @db.Decimal(15,2)
  bankRef          String?
  paymentDate      DateTime?
  paymentMode      String?
  remark           String?
  
  // Bank details mapping
  bankName         String?
  accountName      String?
  accountNumber    String?
  ifscCode         String?

  status           RequestStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
