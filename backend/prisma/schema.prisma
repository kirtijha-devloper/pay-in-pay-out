generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER
  DISTRIBUTOR
  RETAILER
}

enum RequestStatus {
  PENDING
  SUCCESS
  FAILED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  role             Role     @default(RETAILER)
  isActive         Boolean  @default(true)
  kycStatus        KycStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile          Profile?
  wallet           Wallet?

  // Hierarchy bindings
  children         User[]   @relation("UserHierarchy")
  parent           User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  parentId         String?

  services         ServiceRequest[]
  transactionsSent WalletTransaction[] @relation("Sender")
  transactionsRecv WalletTransaction[] @relation("Receiver")
  approvedServiceRequests ServiceRequest[] @relation("ServiceRequestApprovedBy")
  rejectedServiceRequests ServiceRequest[] @relation("ServiceRequestRejectedBy")
  companyBankAccountsCreated CompanyBankAccount[] @relation("CompanyBankAccountCreatedBy")
  companyBankAccountsUpdated CompanyBankAccount[] @relation("CompanyBankAccountUpdatedBy")
  payoutBeneficiaries PayoutBeneficiary[]
  
  defaultSlabsSet  CommissionSlab[]      @relation("DefaultCommissionSetBy")
  overridesSet     UserCommissionSetup[] @relation("SetBy")
  overridesRecv    UserCommissionSetup[] @relation("Target")
}

model Profile {
  id               String   @id @default(uuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String   @unique
  ownerName        String
  shopName         String
  mobileNumber     String   @unique
  fullAddress      String
  state            String
  pinCode          String
  aadhaarNumber    String?
  aadhaarFrontPath String?
  aadhaarBackPath  String?
  panCardPath      String?
}

model Wallet {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  balance   Decimal  @default(0.00) @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id               String   @id @default(uuid())
  amount           Decimal  @db.Decimal(15, 2)
  type             String   // CREDIT, DEBIT
  description      String?
  status           RequestStatus @default(SUCCESS)
  
  sender           User?    @relation("Sender", fields: [senderId], references: [id])
  senderId         String?
  senderBalAfter   Decimal? @db.Decimal(15, 2)
  
  receiver         User     @relation("Receiver", fields: [receiverId], references: [id])
  receiverId       String
  receiverBalAfter Decimal  @db.Decimal(15, 2)
  serviceRequest   ServiceRequest? @relation("ServiceRequestWalletTransactions", fields: [serviceRequestId], references: [id], onDelete: SetNull)
  serviceRequestId String?

  createdAt        DateTime @default(now())
}

model CompanyBankAccount {
  id             String   @id @default(uuid())
  bankName       String
  accountNumber  String   @unique
  ifscCode       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy      User?    @relation("CompanyBankAccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById    String?
  updatedBy      User?    @relation("CompanyBankAccountUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById    String?

  serviceRequests ServiceRequest[]
}

model BankVerificationFee {
  id          String   @id @default("BANK_VERIFICATION")
  amount      Decimal  @default(0.00) @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PayoutBeneficiary {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  payeeName       String   @map("payee_name")
  accountNo       String   @map("account_no")
  bankIfsc        String   @map("bank_ifsc")
  bankName        String   @map("bank_name")
  isVerified      Boolean  @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at")
  providerRef     String?  @map("provider_ref")
  providerStatusCode String? @map("provider_status_code")
  providerResponse String?  @map("provider_response")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, accountNo, bankIfsc])
  @@map("payout_beneficiaries")
}

model CommissionSlab {
  id              String   @id @default(uuid())
  setBy           User     @relation("DefaultCommissionSetBy", fields: [setById], references: [id])
  setById         String
  serviceType     String   // PAYOUT, ADD_FUND, TRANSACTION
  applyOnRole     Role
  commissionType  String   // FLAT, PERCENTAGE
  commissionValue Decimal  @default(0.00) @db.Decimal(15, 2)
  minAmount       Decimal  @default(0.00) @db.Decimal(15, 2)
  maxAmount       Decimal? @db.Decimal(15, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([setById, serviceType, applyOnRole, isActive])
}

model UserCommissionSetup {
  id              String   @id @default(uuid())
  setBy           User     @relation("SetBy", fields: [setById], references: [id])
  setById         String
  targetUser      User     @relation("Target", fields: [targetUserId], references: [id])
  targetUserId    String
  serviceType     String
  commissionType  String   // FLAT, PERCENTAGE
  commissionValue Decimal  @default(0.00) @db.Decimal(15, 2)
  minAmount       Decimal  @default(0.00) @db.Decimal(15, 2)
  maxAmount       Decimal? @db.Decimal(15, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([setById, targetUserId, serviceType, isActive])
}

model ServiceRequest {
  id               String   @id @default(uuid())
  user             User     @relation(fields: [userId], references: [id])
  userId           String
  serviceType      String   // BANK_VERIFICATION, FUND_REQUEST, PAYOUT
  amount           Decimal? @db.Decimal(15,2)
  chargeAmount     Decimal? @db.Decimal(15,2)
  creditedAmount   Decimal? @db.Decimal(15,2)
  bankRef          String?
  paymentDate      DateTime?
  paymentMode      String?
  remark           String?
  receiptPath      String?
  
  // Bank details mapping
  bankName         String?
  accountName      String?
  accountNumber    String?
  ifscCode         String?
  companyBankAccount CompanyBankAccount? @relation(fields: [companyBankAccountId], references: [id], onDelete: SetNull)
  companyBankAccountId String?
  approvedBy       User?    @relation("ServiceRequestApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedById     String?
  approvedAt       DateTime?
  rejectedBy       User?    @relation("ServiceRequestRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedById     String?
  rejectedAt       DateTime?

  walletTransactions WalletTransaction[] @relation("ServiceRequestWalletTransactions")

  status           RequestStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
